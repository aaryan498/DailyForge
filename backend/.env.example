PORT=5000
MONGO_URI=your_mongodb_atlas_connection_string
JWT_SECRET=your_super_secret_key_here # must be at least 32 chars — generate with: openssl rand -hex 32
TWO_FACTOR_ENCRYPTION_KEY=your_64_character_hex_string_run_node_-e_crypto.randomBytes(32).toString('hex')
CLIENT_ORIGIN=your_deployed_frontend_url
FRONTEND_URL=http://localhost:5173
# CORS_ORIGIN: comma-separated list of allowed origins.
# For local development this is set automatically. Only set this
# in production to restrict access to your deployed frontend URL.
# Example: CORS_ORIGIN=https://your-app.onrender.com
# CORS_ORIGIN=
JWT_EXPIRES_IN=7d
NODE_ENV=production #added for samesite domain setting in production and development environment 
# Firebase project configuration for backend token verification
FIREBASE_PROJECT_ID=your_firebase_project_id

# Optional (dev only): allow unverified Firebase tokens when FIREBASE_PROJECT_ID is not configured.
# DO NOT enable this in production.
FIREBASE_AUTH_ALLOW_UNVERIFIED=false
#cloudinary
CLOUD_API_NAME=your_cloudinary_project_name
CLOUD_API_KEY=your_cloudinary_key
CLOUD_API_SECRET=your_cloudinary_secret
CLOUD_API_ENV=your_cloudinary_environmentvariable #see From API keys on cloudinary 


# Two-factor encryption key (required)
TWO_FACTOR_ENCRYPTION_KEY=your_32_char_hex_key_here
# JWT algorithm (optional, defaults to HS256)
JWT_ALGORITHM=HS256
# Auth cookie domain (optional)
AUTH_COOKIE_DOMAIN=localhost

# Email Service
EMAIL_SERVICE=Gmail # Or your email service, e.g., 'SendGrid', 'Outlook365', etc.
EMAIL_FROM=your_email@example.com # Can add your own gmail
EMAIL_PASS=your_email_app_password # Use an app-specific password if using Gmail with 2FA (don't use your actual gmail password create app-specific password in gmail)